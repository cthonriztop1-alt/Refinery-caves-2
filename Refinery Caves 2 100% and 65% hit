-- 攻击循环控制变量
local isAttacking = false
local currentMode = nil
local attackThread = nil

-- 更新按钮状态
local function updateButtonStates()
    if currentMode == 1 then
        Mode1Button.BackgroundColor3 = Color3.fromRGB(40, 120, 200)
        Mode2Button.BackgroundColor3 = Color3.fromRGB(220, 100, 80)
        FloatButton.BackgroundColor3 = Color3.fromRGB(40, 120, 200)
        StatusLabel.Text = "状态: 模式1运行中"
    elseif currentMode == 2 then
        Mode1Button.BackgroundColor3 = Color3.fromRGB(60, 140, 220)
        Mode2Button.BackgroundColor3 = Color3.fromRGB(200, 80, 60)
        FloatButton.BackgroundColor3 = Color3.fromRGB(220, 100, 80)
        StatusLabel.Text = "状态: 模式2运行中"
    else
        Mode1Button.BackgroundColor3 = Color3.fromRGB(60, 140, 220)
        Mode2Button.BackgroundColor3 = Color3.fromRGB(220, 100, 80)
        FloatButton.BackgroundColor3 = Color3.fromRGB(40, 120, 200)
        StatusLabel.Text = "状态: 已停止"
    end
end

-- 攻击函数
local function startAttack(mode)
    -- 停止当前的攻击循环
    if attackThread then
        isAttacking = false
        task.wait(0.1)
        attackThread = nil
    end
    
    currentMode = mode
    isAttacking = true
    updateButtonStates()
    
    -- 启动攻击循环
    attackThread = task.spawn(function()
        while isAttacking and currentMode == mode do
            local args
            
            if mode == 1 then
                -- 模式1: Alpha = 50
                
                args = {
                    {
                        Alpha = 5,
                        ResponseTime = 0
                    }
                }
            else
                -- 模式2: Alpha = 0.65
                args = {
                    {
                        Alpha = 0.65,
                        ResponseTime = 0
                    }
                }
            end
            
            -- 发送攻击请求
            local success, errorMsg = pcall(function()
                game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Tools"):WaitForChild("Attack"):FireServer(unpack(args))
            end)
            
            if not success then
                warn("攻击请求失败: " .. tostring(errorMsg))
                StatusLabel.Text = "状态: 请求失败"
            end
            
            -- 每帧执行一次
            task.wait()
        end
    end)
end

-- 停止攻击函数
local function stopAttack()
    isAttacking = false
    currentMode = nil
    updateButtonStates()
    
    -- 停止线程
    if attackThread then
        attackThread = nil
    end
end

-- UI控制函数
local function toggleMainPanel()
    MainPanel.Visible = not MainPanel.Visible
    if MainPanel.Visible then
        FloatButton.Text = "▼"
    else
        FloatButton.Text = "⚔"
    end
end

-- 按钮点击事件
Mode1Button.MouseButton1Click:Connect(function()
    if currentMode ~= 1 then
        startAttack(1)
    else
        stopAttack()
    end
end)

Mode2Button.MouseButton1Click:Connect(function()
    if currentMode ~= 2 then
