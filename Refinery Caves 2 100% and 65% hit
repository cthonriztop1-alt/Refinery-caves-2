-- 添加拖拽功能（使浮动按钮可移动）
local isDragging = false
local dragStartPosition

FloatButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = true
        dragStartPosition = input.Position
    end
end)

FloatButton.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.Touch then
        local currentPosition = input.Position
        local delta = currentPosition - dragStartPosition
        
        -- 计算新的位置
        local newX = FloatButton.Position.X.Offset + delta.X
        local newY = FloatButton.Position.Y.Offset + delta.Y
        
        -- 限制在屏幕范围内
        newX = math.clamp(newX, 10, 600)  -- 假设屏幕宽度
        newY = math.clamp(newY, 10, 800)  -- 假设屏幕高度
        
        FloatButton.Position = UDim2.new(0, newX, 0, newY)
        
        dragStartPosition = currentPosition
    end
end)

FloatButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = false
    end
end)

-- 自动适应屏幕方向变化
local function updateUIPosition()
    local viewportSize = workspace.CurrentCamera.ViewportSize
    
    -- 更新主面板位置（保持在右侧）
    MainPanel.Position = UDim2.new(1, -260, 0.5, -175)
    
    -- 确保浮动按钮在屏幕内
    local currentX = FloatButton.Position.X.Offset
    local currentY = FloatButton.Position.Y.Offset
    
    currentX = math.clamp(currentX, 10, viewportSize.X - 70)
    currentY = math.clamp(currentY, 10, viewportSize.Y - 70)
    
    FloatButton.Position = UDim2.new(0, currentX, 0, currentY)
end

workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateUIPosition)
updateUIPosition() -- 初始调用

