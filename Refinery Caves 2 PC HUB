-- ================= 核心物理循环 =================
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if state.espEnabled then handleESP() end

    if state.bhActive then
        local s = state.radius * 2
        local anchorPos = hrp.CFrame * CFrame.new(0, 0, -state.distance)
        
        local op = OverlapParams.new(); op.FilterDescendantsInstances = {char}; op.FilterType = Enum.RaycastFilterType.Exclude
        for _, p in ipairs(workspace:GetPartBoundsInBox(hrp.CFrame, Vector3.new(s,s,s), op)) do
            if p:IsA("BasePart") and not p.Anchored and not p.Parent:FindFirstChildOfClass("Humanoid") and not state.lockedParts[p] then
                state.lockedParts[p] = true; p.CanCollide = false
                pcall(function() p:SetNetworkOwner(nil) end)
            end
        end

        for p in pairs(state.lockedParts) do
            if p and p.Parent then
                local bp = p:FindFirstChild("EliteForce") or Instance.new("BodyPosition", p)
                bp.Name = "EliteForce"; bp.MaxForce = Vector3.one * 9e9; bp.P = 15000; bp.D = 400; bp.Position = anchorPos.Position
            else state.lockedParts[p] = nil end
        end
    end
end)

-- 快捷键
UserInputService.InputBegan:Connect(function(io, g)
    if g then return end
    if io.KeyCode == Enum.KeyCode.F then state.bhActive = not state.bhActive
    elseif io.KeyCode == Enum.KeyCode.C then state.bhActive = false end
end)

