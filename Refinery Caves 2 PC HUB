task.spawn(function()
    while true do
        if state.espEnabled then
            local items = workspace:GetDescendants()
            for i, obj in ipairs(items) do
                if not state.espEnabled then break end
                local color = ESP_Targets[obj.Name]
                if color then
                    local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                    if part and not part:FindFirstChild("EliteTag") then
                        local hl = Instance.new("Highlight", part); hl.FillColor = color; hl.FillTransparency = 0.4
                        local bb = Instance.new("BillboardGui", part); bb.Name = "EliteTag"; bb.Size = UDim2.new(0,80,0,30); bb.AlwaysOnTop = true
                        local txt = Instance.new("TextLabel", bb); txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.Text = obj.Name; txt.TextColor3 = color; txt.TextSize = 13; txt.Font = "GothamBold"; txt.TextStrokeTransparency = 0
                    end
                end
                if i % 150 == 0 then task.wait() end -- 极致负载控制
            end
        end
        task.wait(5)
    end
end)

