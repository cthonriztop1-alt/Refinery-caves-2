-- ================= ESP 核心 =================
local function handleESP()
    if not state.espEnabled then return end
    if tick() - state.lastScan < 6 then return end
    state.lastScan = tick()

    local ws = workspace:FindFirstChild("WorldSpawn")
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not ws or not hrp then return end

    for i, obj in ipairs(ws:GetDescendants()) do
        local data = ESP_Targets[obj.Name]
        if data then
            local part = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
            if part then
                local dist = (part.Position - hrp.Position).Magnitude
                local maxDist = data.allMap and 99999 or 1500
                
                if dist <= maxDist then
                    if not part:FindFirstChild("EliteTag") then
                        local hl = Instance.new("Highlight", part)
                        hl.Name = "EliteHighlight"; hl.FillColor = data.c; hl.FillTransparency = 0.6
                        
                        local bb = Instance.new("BillboardGui", part)
                        bb.Name = "EliteTag"; bb.Size = UDim2.new(0, 100, 0, 40); bb.AlwaysOnTop = true; bb.ExtentsOffset = Vector3.new(0,3,0)
                        local txt = Instance.new("TextLabel", bb)
                        txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.Font = "GothamBold"; txt.TextSize = 14
                        txt.TextColor3 = data.c; txt.TextStrokeTransparency = 0; txt.Text = obj.Name
                    end
                else
                    if part:FindFirstChild("EliteTag") then part.EliteTag:Destroy() end
                    if part:FindFirstChild("EliteHighlight") then part.EliteHighlight:Destroy() end
                end
            end
        end
        if i % 50 == 0 then task.wait() end 
    end
end

-- ================= 自动钓鱼逻辑 [已补回] =================
local ChangeFishPull = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Tools"):WaitForChild("ChangeFishPull")
task.spawn(function()
    while true do
        if state.fishEnabled then
            local gui = PlayerGui:FindFirstChild("UserGui")
            local catch = gui and gui:FindFirstChild("CatchFrame")
            if catch and catch.Visible then
                local f = catch:FindFirstChild("Fish")
                if f then
                    local r = math.floor(f.Rotation % 360); if r < 0 then r += 360 end
                    if r == 0 then ChangeFishPull:FireServer({Side = "Left"})
                    elseif r == 90 then ChangeFishPull:FireServer({Side = "Top"})
                    elseif r == 180 then ChangeFishPull:FireServer({Side = "Right"})
                    elseif r == 270 then ChangeFishPull:FireServer({Side = "Bottom"}) end
                end
            end
        end
        task.wait(0.05)
    end
end)

