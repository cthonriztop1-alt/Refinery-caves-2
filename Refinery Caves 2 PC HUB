-- ================= 核心：暴力释放与停稳 =================
local function releaseAll()
    state.bhActive = false
    state.lockPosition = nil
    RangeVisual.Transparency = 1
    if BhToggle then BhToggle:Set(false) end
    for p, _ in pairs(state.lockedParts) do
        if p and p.Parent then
            if p:FindFirstChild("EliteForce") then p.EliteForce:Destroy() end
            if p:FindFirstChild("EliteGyro") then p.EliteGyro:Destroy() end
            p.AssemblyLinearVelocity = Vector3.zero
            p.AssemblyAngularVelocity = Vector3.zero
            task.delay(0.1, function()
                if p and p.Parent then 
                    p.CanCollide = true
                    pcall(function() p:SetNetworkOwner(LocalPlayer) end) 
                end
            end)
        end
    end
    table.clear(state.lockedParts)
end

-- ================= 自动钓鱼 (原始逻辑同步) =================
local ChangeFishPull = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Tools"):WaitForChild("ChangeFishPull")
task.spawn(function()
    while task.wait() do 
        if state.fishEnabled then
            local gui = PlayerGui:FindFirstChild("UserGui")
            local catchFrame = gui and gui:FindFirstChild("CatchFrame")
            if catchFrame and catchFrame.Visible then
                local fish = catchFrame:FindFirstChild("Fish")
                if fish then
                    local rotation = math.floor(fish.Rotation % 360)
                    if rotation < 0 then rotation = rotation + 360 end
                    if rotation == 0 then ChangeFishPull:FireServer({Side = "Left"})
                    elseif rotation == 90 then ChangeFishPull:FireServer({Side = "Top"})
                    elseif rotation == 180 then ChangeFishPull:FireServer({Side = "Right"})
                    elseif rotation == 270 then ChangeFishPull:FireServer({Side = "Bottom"})
                    end
                end
            end
        end
    end
end)

-- ================= 黑洞：复刻 V10.17 暴力算法 =================

-- 1. 扫描零件 (优化掉帧：保持灵敏且低载)
task.spawn(function()
    while true do
        task.wait(0.12)
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and state.bhActive then
            state.lockPosition = (hrp.CFrame * CFrame.new(0, 0, -state.distance)).Position
            
            RangeVisual.Transparency = 0.7
            RangeVisual.Size = Vector3.one * (state.radius * 2)
            RangeVisual.CFrame = hrp.CFrame
            
            local op = OverlapParams.new()
            op.FilterDescendantsInstances = {char, RangeVisual}
            op.FilterType = Enum.RaycastFilterType.Exclude
            local parts = workspace:GetPartBoundsInBox(hrp.CFrame, RangeVisual.Size, op)
            for _, p in ipairs(parts) do
                if p:IsA("BasePart") and not p.Anchored and not p.Parent:FindFirstChildOfClass("Humanoid") then
                    if not state.lockedParts[p] then
                        state.lockedParts[p] = true
                        p.CanCollide = false
                        pcall(function() p:SetNetworkOwner(nil) end)
                    end
                end
            end
        else
            RangeVisual.Transparency = 1
        end
    end
end)

-- 2. 暴力物理：瞬间对齐 (Heartbeat)
RunService.Heartbeat:Connect(function()
    if not state.lockPosition then return end
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- V10.17 核心：暴力角度校准，所有物体吸附时保持一致朝向
    local alignRot = CFrame.lookAt(state.lockPosition, state.lockPosition + hrp.CFrame.LookVector)
    
    for p, _ in pairs(state.lockedParts) do
        if p and p.Parent and not p.Anchored then
            -- 高 P 值 BodyPosition (瞬间锁死坐标)
            local bp = p:FindFirstChild("EliteForce") or Instance.new("BodyPosition", p)
            bp.Name = "EliteForce"; bp.MaxForce = Vector3.one * 9e9; bp.P = 25000; bp.D = 400; bp.Position = state.lockPosition
            
            -- 高 P 值 BodyGyro (暴力防止乱飞)
            local bg = p:FindFirstChild("EliteGyro") or Instance.new("BodyGyro", p)
            bg.Name = "EliteGyro"; bg.MaxTorque = Vector3.one * 9e9; bg.P = 15000; bg.D = 100; bg.CFrame = alignRot
        else
            state.lockedParts[p] = nil
        end
    end
end)

