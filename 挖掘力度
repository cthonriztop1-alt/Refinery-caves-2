-- [[ RC2 纯净版攻击切换器 - MMMMMMM 修改版 ]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AttackEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Tools"):WaitForChild("Attack")

local state = {
    attackMode = 0 
}

-- ================= 核心攻击循环 =================
task.spawn(function()
    while true do
        if state.attackMode > 0 then
            local alphaVal = 1
            if state.attackMode == 1 then 
                alphaVal = math.huge 
            elseif state.attackMode == 2 then 
                alphaVal = 0.65      
            elseif state.attackMode == 3 then 
                alphaVal = 1.0       
            end
            
            pcall(function()
                AttackEvent:FireServer({
                    Alpha = alphaVal,
                    ResponseTime = 0
                })
            end)
        end
        task.wait() 
    end
end)

