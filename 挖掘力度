-- -----------------------

local function createBtn(text, yPos, color, mode)
    local btn = Instance.new("TextButton", Container)
    btn.Size = UDim2.new(1, -10, 0, 40)
    btn.Position = UDim2.new(0, 5, 0, yPos)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.BorderSizePixel = 0
    
    btn.MouseButton1Click:Connect(function()
        state.attackMode = mode
    end)
    return btn
end

createBtn("模式 1 (Alpha = ∞)", 10, Color3.fromRGB(60, 140, 220), 1)
createBtn("模式 2 (Alpha = 0.65)", 60, Color3.fromRGB(220, 100, 80), 2)
createBtn("模式 3 (Spore Axe = 1.0)", 110, Color3.fromRGB(0, 170, 80), 3)
