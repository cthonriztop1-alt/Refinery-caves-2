-- 攻击循环逻辑
local isAttacking = false
local currentMode = nil
local attackThread = nil

local function updateButtonStates()
    if currentMode == 1 then
        StatusLabel.Text = "状态: 模式1运行中 (∞)"
    elseif currentMode == 2 then
        StatusLabel.Text = "状态: 模式2运行中 (0.65)"
    else
        StatusLabel.Text = "状态: 已停止"
    end
end

local function startAttack(mode)
    if attackThread then
        isAttacking = false
        task.wait(0.1)
    end
    
    currentMode = mode
    isAttacking = true
    updateButtonStates()
    
    attackThread = task.spawn(function()
        local event = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Tools"):WaitForChild("Attack")
        while isAttacking and currentMode == mode do
            local alphaVal = (mode == 1) and math.huge or 0.65 -- 这里改成了 math.huge (无穷大)
            local args = {{Alpha = alphaVal, ResponseTime = 0}}
            
            pcall(function()
                event:FireServer(unpack(args))
            end)
            task.wait()
        end
    end)
end

local function stopAttack()
    isAttacking = false
    currentMode = nil
    updateButtonStates()
end

-- 交互事件
Mode1Button.MouseButton1Click:Connect(function()
    if currentMode ~= 1 then startAttack(1) else stopAttack() end
end)

Mode2Button.MouseButton1Click:Connect(function()
    if currentMode ~= 2 then startAttack(2) else stopAttack() end
end)

StopButton.MouseButton1Click:Connect(stopAttack)
FloatButton.MouseButton1Click:Connect(function() MainPanel.Visible = not MainPanel.Visible end)
CloseButton.MouseButton1Click:Connect(function() MainPanel.Visible = false end)

